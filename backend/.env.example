# Copy this file to .env and fill in your values
# Never commit .env to GitHub

# Server
PORT=5000
NODE_ENV=development

# Prisma database. Local development uses SQLite, so no DB password is needed.
# Production can use PostgreSQL/MySQL by updating prisma/schema.prisma provider and this URL.
DATABASE_URL="file:../dev.db"

# JWT
# Production requires a unique value with at least 32 characters.
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# CORS - comma-separated frontend URLs allowed to call the API
FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173

# Security and rate limiting
# Use TRUST_PROXY=1 when the API runs behind one reverse proxy/load balancer.
TRUST_PROXY=0
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_API_MAX=500
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_LOCAL_SECRETS_MAX=60

# Observability
# Production enables request logs by default; set explicitly to override.
LOG_REQUESTS=false

# Media storage
# local keeps uploads in backend/uploads for development.
# cloudinary sends uploads to Cloudinary and requires the credentials below.
MEDIA_STORAGE_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=tribe-trip

# Optional local development accounts. The scripts below use these defaults:
# npm run dev:editor / npm run dev:admin / npm run dev:super-admin
DEV_EDITOR_EMAIL=editor@tribetrip.local
DEV_EDITOR_PASSWORD=EditorPass123
DEV_EDITOR_NAME=Tribe Trip Editor
DEV_ADMIN_EMAIL=admin@tribetrip.local
DEV_ADMIN_PASSWORD=AdminPass123
DEV_ADMIN_NAME=Tribe Trip Admin
DEV_SUPER_ADMIN_EMAIL=superadmin@tribetrip.local
DEV_SUPER_ADMIN_PASSWORD=SuperAdminPass123
DEV_SUPER_ADMIN_NAME=Tribe Trip Super Admin
