# Copy this file to backend/.env for local development.
# Never commit real .env files or real secrets to GitHub.
#
# Production/Vercel variables you must fill out:
# - NODE_ENV=production
# - DATABASE_URL or POSTGRES_PRISMA_URL or POSTGRES_URL with a PostgreSQL connection string
# - JWT_SECRET with a unique 32+ character secret
# - FRONTEND_URLS with your production frontend URL(s)
# - MEDIA_STORAGE_PROVIDER=supabase or MEDIA_STORAGE_PROVIDER=cloudinary
# - SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_STORAGE_BUCKET when using Supabase Storage
# - CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET when using Cloudinary

# Server
PORT=5000
NODE_ENV=development

# Database
# Local development uses SQLite, so no DB password is needed.
DATABASE_URL="file:../dev.db"

# Production/Vercel requires PostgreSQL. Fill ONE of these in Vercel.
# Vercel Postgres usually provides POSTGRES_PRISMA_URL or POSTGRES_URL automatically.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# POSTGRES_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# JWT
# Production requires a unique value with at least 32 characters.
# Generate one with: openssl rand -base64 48
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# CORS
# Comma-separated frontend URLs allowed to call the API.
# For Vercel production, include your real Vercel/custom domain.
FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173

# Security and rate limiting
# Use TRUST_PROXY=1 when the API runs behind one reverse proxy/load balancer.
# Vercel sets VERCEL=1 automatically; you normally do not set it yourself.
TRUST_PROXY=0
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_API_MAX=500
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_LOCAL_SECRETS_MAX=60

# Observability
# Production enables request logs by default; set explicitly to override.
LOG_REQUESTS=false

# Media storage
# local keeps uploads in backend/uploads for development only.
# Vercel/serverless production must use supabase or cloudinary because local files are ephemeral.
MEDIA_STORAGE_PROVIDER=local

# Supabase Storage production option.
# SUPABASE_SERVICE_ROLE_KEY is server-only. Never expose it to frontend code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=tribe-trip-media

# Cloudinary production option.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=tribe-trip

# Optional local development accounts. The scripts below use these defaults:
# npm run dev:editor / npm run dev:admin / npm run dev:super-admin
DEV_EDITOR_EMAIL=editor@tribetrip.local
DEV_EDITOR_PASSWORD=EditorPass123
DEV_EDITOR_NAME=Tribe Trip Editor
DEV_ADMIN_EMAIL=admin@tribetrip.local
DEV_ADMIN_PASSWORD=AdminPass123
DEV_ADMIN_NAME=Tribe Trip Admin
DEV_SUPER_ADMIN_EMAIL=superadmin@tribetrip.local
DEV_SUPER_ADMIN_PASSWORD=SuperAdminPass123
DEV_SUPER_ADMIN_NAME=Tribe Trip Super Admin
