# Frontend development environment
# Copy to .env.local for local-only overrides. Do not put secrets here.

# Local backend API. In a single Vercel project, production defaults to same-origin /api.
# Set VITE_API_URL only when the API is hosted on a different origin.
VITE_API_URL=http://localhost:5000/api

# Production Docker/Nginx can override the API URL at container startup through
# TRIBE_TRIP_API_URL without rebuilding the frontend image.
