{
  "framework": "vite",
  "installCommand": "npm ci --include=dev && npm --prefix backend ci --include=dev",
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "functions": {
    "api/[...path].js": {
      "maxDuration": 10
    },
    "api/auth/[...path].js": {
      "maxDuration": 10
    },
    "api/admin/[...path].js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
