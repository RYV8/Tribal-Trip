# Docker Compose production-local environment
# Generate a long random value before using this stack outside local testing.
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Keep /api when frontend and backend are served by the same Nginx container.
# Use a full URL only when the API is hosted separately.
TRIBE_TRIP_API_URL=/api
FRONTEND_URLS=http://localhost:8080,http://127.0.0.1:8080
LOG_REQUESTS=true

# Docker preview default. For managed production DBs, update Prisma provider first.
DATABASE_URL=file:../data/prod.db
TRUST_PROXY=1
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_API_MAX=500
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_LOCAL_SECRETS_MAX=60

# Set RUN_SEED=true for the first local production preview if the SQLite DB is empty.
RUN_SEED=false

MEDIA_STORAGE_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=tribe-trip
